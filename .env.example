# Perch environment variables. Copy to .env and fill in real values locally.
# NEVER commit a real .env. The .env file is gitignored; this placeholder
# template is the only env file that belongs in the repo.

# Master key for Perch's identity/crypto spine. Keep this secret. Generate a
# strong random value. Required for non-stdlib (Ed25519) operation.
PERCH_MASTER_KEY=

# Crypto backend selector. Set to "stdlib" to force the HMAC stdlib baseline,
# or leave blank to use the optional Ed25519 upgrade when the crypto extra is
# installed.
PERCH_CRYPTO_BACKEND=
